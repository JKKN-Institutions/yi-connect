# =============================================================================
# yi-connect — environment variables example
# =============================================================================
# Copy this file to `.env.local` and fill in real values. NEVER commit
# `.env.local` (it is .gitignored). NEVER put real secrets in this file.
# =============================================================================

# ---------------------------------------------------------------------------
# Sentry — error tracking
# ---------------------------------------------------------------------------
# Get from https://sentry.io  →  Project Settings → Client Keys (DSN).
# Leave empty / unset to disable Sentry locally (no DSN = no init, no noise).
# TODO: Director to set the real DSN for production via Vercel env vars.
NEXT_PUBLIC_SENTRY_DSN=<TO BE SET BY DIRECTOR>

# Optional — only needed for source-map upload at build time.
# When set, builds will upload sourcemaps to Sentry for symbolicated stack traces.
# SENTRY_AUTH_TOKEN=<TO BE SET BY DIRECTOR>
# SENTRY_ORG=<TO BE SET BY DIRECTOR>
# SENTRY_PROJECT=yi-connect

# ---------------------------------------------------------------------------
# Vercel Analytics — page views (no config required)
# ---------------------------------------------------------------------------
# Vercel Analytics auto-attaches to the deployment when @vercel/analytics is
# loaded. No env vars needed. Routes to Vercel's free tier automatically.
